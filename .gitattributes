# Git line ending settings
# gradlew must use LF on all platforms (Unix shell script)
gradlew              text eol=lf
gradlew.bat          text eol=crlf
*.sh                 text eol=lf
*.bat                text eol=crlf
*.ps1                text eol=crlf

# Source files
*.kt                 text eol=lf
*.kts                text eol=lf
*.xml                text eol=lf
*.java               text eol=lf
*.md                 text eol=lf
*.properties         text eol=lf
*.toml               text eol=lf

# Binary files
*.jar                binary
*.png                binary
*.webp               binary
*.keystore           binary
